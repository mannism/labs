{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "parserOpts": {
          "headerPattern": "^(?:\\[v[\\d.]+\\] )?(\\w*)(?:\\(([\\w$.* -]*)\\))?!?: (.*)$",
          "headerCorrespondence": ["type", "scope", "subject"]
        },
        "releaseRules": [
          { "type": "feature", "release": "minor" },
          { "type": "bugfix", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "chore", "release": "patch" },
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "parserOpts": {
          "headerPattern": "^(?:\\[v[\\d.]+\\] )?(\\w*)(?:\\(([\\w$.* -]*)\\))?!?: (.*)$",
          "headerCorrespondence": ["type", "scope", "subject"]
        }
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/\\*\\*Version:\\*\\* [0-9][0-9.]*/\\*\\*Version:\\*\\* ${nextRelease.version}/' README.md && npm version ${nextRelease.version} --no-git-tag-version --allow-same-version"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["README.md", "package.json"],
        "message": "chore(release): sync README to v${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}
