# .env.example
# Copy to .env or .env.local and fill in values. Never commit the filled file.
# Variables marked (required) must be set — the app will not function without them.
# Variables marked (optional) have a safe default and can be omitted.

# ─── Chat engine (OpenAI / Digital Twin) ─────────────────────────────────────

# OpenAI secret key — used for all chat completions and summarisation.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Primary chat model. Defaults to gpt-5.4-mini if unset. (optional)
OPENAI_MODEL=gpt-5.4-mini

# Summarisation model — lighter model used to compress long conversation history.
# Defaults to gpt-5.4-nano if unset. (optional)
OPENAI_MODEL_SUMMARY=gpt-5.4-nano

# Maximum character length of a single user message before the API rejects it.
# Defaults to 4000 if unset. (optional)
MAX_MESSAGE_LENGTH=4000

# ─── Anthropic / EXP_005 Brand Pipeline ──────────────────────────────────────

# Anthropic secret key — required for the EXP_005 Autonomous Brand Pipeline experiment.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Anthropic model used for the generate step of the brand pipeline.
# Defaults to claude-haiku-4-5-20251001. (optional)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Anthropic model used for the evaluate/rank steps of the brand pipeline.
# Defaults to the same value as ANTHROPIC_MODEL. (optional)
ANTHROPIC_EVAL_MODEL=

# Maximum token budget for a single generate-step call. Defaults to 4096. (optional)
ANTHROPIC_MAX_TOKENS=4096

# ─── EXP_009 — Reliability Dashboard (Gemini provider) ───────────────────────

# Google AI (Gemini) API key — required for EXP_009.
# Generate one at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# ─── Redis ───────────────────────────────────────────────────────────────────

# Redis connection URL. Used for session history, rate limiting, and BullMQ queues.
# Defaults to redis://localhost:6379 for local development. (optional for local dev)
REDIS_URL=redis://localhost:6379

# ─── Rate limiting ────────────────────────────────────────────────────────────

# Maximum number of chat messages allowed per session within the rate-limit window.
# Defaults to 5. (optional)
RATE_LIMIT_COUNT=5

# Rate-limit window in seconds. Defaults to 60. (optional)
RATE_LIMIT_WINDOW=60

# ─── Conversation summarisation ───────────────────────────────────────────────

# Number of messages in a session's history that triggers automatic summarisation.
# Defaults to 30. (optional)
SUMMARISATION_THRESHOLD=30

# ─── Telegram bot ────────────────────────────────────────────────────────────

# Telegram Bot API token — obtain from @BotFather. Required if running the Telegram bot.
TELEGRAM_TOKEN=

# Shared secret used to verify that webhook requests originate from Telegram.
# Set the same value when registering the webhook with Telegram's setWebhook API.
TELEGRAM_WEBHOOK_SECRET=

# ─── Site ────────────────────────────────────────────────────────────────────

# Public base URL of this deployment. Used to build absolute links in Telegram messages.
# Defaults to https://labs.dianaismail.me. (optional)
LABS_URL=https://labs.dianaismail.me

# Public URL of the chat API — used by the ChatWidget client component.
# Set when the chat API is hosted on a different origin from the Next.js app. (optional)
NEXT_PUBLIC_CHAT_API_URL=

# ─── Analytics ────────────────────────────────────────────────────────────────

# Google Analytics measurement ID (G-XXXXXXXXXX).
# Omit to disable GA entirely — the component loads conditionally. (optional)
NEXT_PUBLIC_GA_ID=
